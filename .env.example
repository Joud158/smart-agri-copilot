# =========================
# Root environment example
# =========================

# -------- LLM for Agent System A (LangGraph) --------
# Use any OpenAI-compatible provider. Examples:
# - OpenAI
# - Groq-compatible gateways
# - OpenRouter
OPENAI_API_KEY=replace_me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# -------- Agent System B / ADK --------
# Agent System B can use Google ADK when a Gemini key is available.
# The code also includes a deterministic fallback so local demos do not fail hard.
GOOGLE_API_KEY=replace_me
ADK_MODEL=gemini-3-flash-preview

# -------- Shared retrieval config --------
EMBEDDING_MODEL=text-embedding-3-small
QDRANT_URL=http://vector-db:6333
QDRANT_COLLECTION=smart_agri_docs
TOP_K=4
RAG_CHUNK_SIZE=650
RAG_CHUNK_OVERLAP=120

# -------- Service-to-service URLs --------
AGENT_B_URL=http://agent-system-b:8102
MCP_SERVER_URL=http://mcp-server:8103

# -------- API / App config --------
SESSION_DB_PATH=/data/sessions.sqlite
REQUEST_TIMEOUT_SECONDS=20
ALLOW_OUT_OF_DOMAIN=false
FRONTEND_PORT=3000
