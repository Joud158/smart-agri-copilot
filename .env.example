# ---------- Shared ----------
REQUEST_TIMEOUT_SECONDS=25
SERVICE_RETRY_ATTEMPTS=2
SERVICE_RETRY_BACKOFF_MS=300

# Default run mode is stable and offline-friendly.
# You can switch to OpenAI/Ollama later without changing code.
LLM_PROVIDER=none
ENABLE_REACT_AGENT=false
ENABLE_LLM_SYNTHESIS=false
AGENT_PATTERN=deterministic
MAX_TOOL_STEPS=4

OPENAI_API_KEY=replace_me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_VISION_MODEL=gemma3:4b-it-qat
ENABLE_VISION_INGESTION=false

ENABLE_WEB_SEARCH=true
ENABLE_QUERY_TRANSLATION_FALLBACK=false
QDRANT_URL=http://vector-db:6333
QDRANT_COLLECTION=smart_agri_docs
EMBEDDING_PROVIDER=local_deterministic
EMBEDDING_MODEL=local-deterministic-v2
RERANKER_MODE=hybrid_lexical
TOP_K=5
RAG_FETCH_K=12
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=180
MAX_SPECIALIST_STEPS=6
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ADMIN_API_TOKEN=change_me
SESSION_TTL_HOURS=24
ALLOW_OUT_OF_DOMAIN=false

# ---------- Agent A ----------
AGENT_B_URL=http://agent-system-b:8102
MCP_SERVER_URL=http://mcp-server:8103
MCP_STREAMABLE_HTTP_PATH=/mcp
ENABLE_MCP_CLIENT=true
SESSION_DB_PATH=/data/sessions.sqlite

# ---------- Agent B ----------
GOOGLE_API_KEY=replace_me
ADK_MODEL=gemini-3-flash-preview
AGENT_B_MODE=auto
AGENT_B_USER_ID=smart_agri_agent_a
SESSION_DB_PATH_AGENT_B=/data/agent_b_sessions.sqlite

# ---------- Ingestion ----------
DATA_ROOT=/workspace/data
LOCAL_EMBEDDING_DIMENSION=256

# ---------- Evaluation ----------
GENERATION_EVAL_MODE=heuristic
GENERATION_EVAL_MODEL=gpt-4o-mini
